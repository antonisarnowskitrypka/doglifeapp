rules_version = '2';

// Clients never access Firestore directly — all data flows through Nuxt server
// routes using the Admin SDK (which bypasses these rules). Deny everything else.
// See docs/dev-docs/03-firebase-and-security.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

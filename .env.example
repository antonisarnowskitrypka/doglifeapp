# Copy to .env and fill per environment. See docs/dev-docs/10-development-setup.md#environments.
# Same variable NAMES across LOCAL / DEV / PROD — only VALUES differ.
# LOCAL uses the demo values below + the Firebase Emulator Suite.

# Firebase (client) — DEV/PROD: real project values; LOCAL: demo project
NUXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-doglifeapp.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=demo-doglifeapp
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-doglifeapp.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NUXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo000000000000

# Site (SEO module)
NUXT_PUBLIC_SITE_URL=http://localhost:9000

# Firebase Emulators — set on LOCAL to route the Admin SDK at the emulators (unset in DEV/PROD)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
# Admin/GCS SDK reads STORAGE_EMULATOR_HOST (needs the http:// scheme) to target the emulator.
STORAGE_EMULATOR_HOST=http://127.0.0.1:9199
VUEFIRE_EMULATORS=true

# Stripe — test keys on LOCAL/DEV, live keys on PROD
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend — sandbox sender on LOCAL/DEV, production domain on PROD
RESEND_API_KEY=

# Geocoding & static maps — server-side only (NEVER NUXT_PUBLIC_*). See dev-docs/36-geocoding-and-maps.md.
# Geoapify covers geocoding + address autocomplete + static maps on one key; ToS permits storing coords.
GEOAPIFY_API_KEY=
# LOCATIONIQ_API_KEY=   # fallback provider (same role); uncomment to switch the geocode adapter
